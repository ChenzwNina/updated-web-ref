ANTHROPIC_API_KEY=your_anthropic_key_here

# Get an Access Key at https://unsplash.com/developers → "New Application".
# Without this the image replacer falls back to LoremFlickr (weaker keyword match).
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Optional: override defaults
# MAIN_AGENT_MODEL=claude-opus-4-6
# SUBAGENT_MODEL=claude-sonnet-4-6
